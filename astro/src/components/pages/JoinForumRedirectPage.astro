---
import { t } from '@/i18n/translate';
import type { PageProps } from './PageProps';

const { locale } = Astro.props as PageProps;
---
<div class="title center">
  <h1>{t(locale, 'join.join_register_page.title')}</h1>
</div>
<div class="main">
  <div class="mainBlock center widepadding">
    <p>{t(locale, 'join.join_register_page.description')}</p>
    <p><a id="joinForumFallback" href="/blackboard/questionnaire/22_07_04_join_nmteam_developer">Continue</a></p>
  </div>
</div>
<script is:inline>
  (() => {
    const allowedJobTypes = new Set(["developer", "support", "writer"]);
    const params = new URLSearchParams(window.location.search);
    const requestedJobType = params.get("jobType") || "developer";
    const jobType = allowedJobTypes.has(requestedJobType) ? requestedJobType : "developer";
    const target = `/blackboard/questionnaire/22_07_04_join_nmteam_${jobType}`;
    const fallback = document.getElementById("joinForumFallback");
    if (fallback) {
      fallback.setAttribute("href", target);
    }
    window.location.replace(target);
  })();
</script>

