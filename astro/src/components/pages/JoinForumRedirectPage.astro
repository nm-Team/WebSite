---
import { t } from '@/i18n/translate';
import type { PageProps } from './PageProps';

const { locale } = Astro.props as PageProps;
---
<div class="title center">
  <h1>{t(locale, 'join.join_register_page.title')}</h1>
</div>
<div class="main">
  <div class="mainBlock center widepadding">
    <p>{t(locale, 'join.join_register_page.description')}</p>
    <p><a id="joinForumFallback" href="/questionnaire-ended/">Continue</a></p>
  </div>
</div>
<script is:inline>
  (() => {
    const target = "/questionnaire-ended/";
    const fallback = document.getElementById("joinForumFallback");
    if (fallback) {
      fallback.setAttribute("href", target);
    }
    window.location.replace(target);
  })();
</script>
