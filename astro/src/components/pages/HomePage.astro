---
import { toLocalizedHref } from '@/i18n/links';
import { t } from '@/i18n/translate';
import type { PageProps } from './PageProps';

const { locale } = Astro.props as PageProps;

const href = (path: string) => toLocalizedHref(locale, path);
const externalIcon = `<svg class="svg" style="transform:scale(0.81)" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M924.402464 1023.068211H0.679665V99.345412h461.861399v98.909208H99.596867v725.896389h725.896389V561.206811h98.909208z"></path><path d="M930.805104 22.977336l69.965436 69.965436-453.492405 453.492404-69.965435-69.901489z"></path><path d="M1022.464381 304.030081h-98.917201V99.345412H709.230573V0.428211h313.233808z"></path></svg>`;
const arrowIcon = `<svg class="svg" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M761.056 532.128c0.512-0.992 1.344-1.824 1.792-2.848 8.8-18.304 5.92-40.704-9.664-55.424L399.936 139.744c-19.264-18.208-49.632-17.344-67.872 1.888-18.208 19.264-17.376 49.632 1.888 67.872l316.96 299.84-315.712 304.288c-19.072 18.4-19.648 48.768-1.248 67.872 9.408 9.792 21.984 14.688 34.56 14.688 12 0 24-4.48 33.312-13.44l350.048-337.376z"></path></svg>`;
---
<script is:inline define:vars={{
  newsRoomLoadingI18n: t(locale, 'index.newslist_loading'),
  newsRoomTimeI18n: t(locale, 'index.newslist_date_aria_label'),
  newsRoomLoadFailedI18n: t(locale, 'index.newslist_error'),
  newsRoomRetryI18n: t(locale, 'index.retry'),
}}>
  window.newsRoomLoadingI18n = newsRoomLoadingI18n;
  window.newsRoomTimeI18n = newsRoomTimeI18n;
  window.newsRoomLoadFailedI18n = newsRoomLoadFailedI18n;
  window.newsRoomRetryI18n = newsRoomRetryI18n;
</script>
<div class="indexHeader">
  <i></i>
</div>
<div class="main">
  <div class="mainBlock center widepadding">
    <h1>{t(locale, 'index.what_is_nmteam')}</h1>
    <p>{t(locale, 'index.nmteam_is_this_a')}</p>
    <p>{t(locale, 'index.nmteam_is_this_b')}</p>
    <div class="indexMoreLinks">
      <a target="_blank" href={href('/aboutus')}>
        <span>{t(locale, 'index.nmteam_about_link')}</span>
        <Fragment set:html={arrowIcon} />
      </a>
    </div>
  </div>
  <div class="mainBlock center widepadding">
    <h1>{t(locale, 'index.what_we_does')}</h1>
    <p>{t(locale, 'index.what_we_does_ans')}</p>
    <div class="swiper cardSwiper productsSwiper" data-grow>
      <div class="swiper-wrapper">
        <a href={href('/products/overview/nmBot-Telegram')} target="_self" class="swiper-slide" style="background-image: url(https://websiteres.nmteam.xyz/producticon/nmBot/nmbot_next.jpg)">
          <p>nmBot</p>
        </a>
        <a href="https://nmbot.nmnm.fun" target="_blank" class="swiper-slide" style="background-image: url(https://websiteres.nmteam.xyz/producticon/nmBot/logo@128.png)">
          <p>nmBot Panel</p>
        </a>
        <a href={href('/products/overview/nmBrowser-StartPage')} target="_self" class="swiper-slide" style="background-image: url(https://websiteres.nmteam.xyz/producticon/nmBrowser/logo@128.png)">
          <p>nmBrowser StartPage</p>
        </a>
        <a href={href('/products/overview/nmFun')} target="_self" class="swiper-slide" style="background-image: url(https://websiteres.nmteam.xyz/producticon/nmFun/logo.svg)">
          <p>nmFun</p>
        </a>
      </div>
    </div>
    <div class="indexMoreLinks">
      <a target="_blank" href={href('/products')}>
        <span>{t(locale, 'index.more_products')}</span>
        <Fragment set:html={arrowIcon} />
      </a>
    </div>
  </div>
  <div class="mainBlock center widepadding">
    <h1>{t(locale, 'index.newslist')}</h1>
    <div class="swiper cardSwiper newsSwiper" data-grow>
      <div class="swiper-wrapper" id="newsSwiperItems">{t(locale, 'index.newslist_loading')}</div>
    </div>
    <div class="indexMoreLinks">
      <a target="_blank" rel="noopener noreferrer" href="https://newsroom.nmteam.xyz?ref=nmteam.xyz">
        <span>{t(locale, 'index.newslist_more')}</span>
        <Fragment set:html={externalIcon} />
      </a>
    </div>
  </div>
  <div class="mainBlock center widepadding">
    <h1>{t(locale, 'index.connect_us')}</h1>
    <p>{t(locale, 'index.connect_para')}</p>
    <div class="indexMoreLinks">
      <a href="https://github.com/nm-Team" target="_blank"><b>GitHub&nbsp;</b>@nm-Team<Fragment set:html={externalIcon} /></a>
      <a href="https://t.me/nmteamnewsroom" target="_blank"><b>Telegram&nbsp;</b>@nmteamnewsroom<Fragment set:html={externalIcon} /></a>
      <a href="https://twitter.com/nmnmfun" target="_blank"><b>X&nbsp;</b>@nmnmfun<Fragment set:html={externalIcon} /></a>
    </div>
    <h1>{t(locale, 'index.join_us')}</h1>
    <p>{t(locale, 'index.join_para')}</p>
    <p>{t(locale, 'index.join_para_2')}</p>
    <div class="indexMoreLinks">
      <a target="_blank" href={href('/join')}>
        <span>{t(locale, 'index.join_us_link')}</span>
        <Fragment set:html={arrowIcon} />
      </a>
    </div>
  </div>
</div>
<img src="https://websiteres.nmteam.xyz/nmwebsite/index/nmTeam_Website_Lemon_Line_Img.png" class="lemonLine" ondragstart="return false;" oncontextmenu="return false;" alt="Lemon Production Line" />
