---
import { t } from '@/i18n/translate';
import type { PageProps } from './PageProps';

const { locale } = Astro.props as PageProps;
---
<style>
  .cookieSettingBox {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 20px 0;
  }

  .cookieSettingBox label {
    margin-inline-end: 15px;
  }
</style>
<div class="title center">
  <h1>{t(locale, 'cookies.title')}</h1>
</div>
<div class="main mainBlock">
  <center>{t(locale, 'cookies.description')}</center>
  <h2>{t(locale, 'cookies.necessary_cookies_title')}</h2>
  <center>{t(locale, 'cookies.necessary_cookies_description')}</center>
  <h2>{t(locale, 'cookies.optional_cookies_title')}</h2>
  <center>{t(locale, 'cookies.optional_cookies_description')}</center>
  <div class="cookieSettingBox">
    <label for="operationCookiesSwitchButton">{t(locale, 'cookies.optional_cookies_title')}</label>
    <div class="select-radio-box">
      <input type="checkbox" id="operationCookiesSwitchButton" class="operationCookiesSwitchButton" checked />
      <div class="select-switch">
        <div class="select-cursor"></div>
        <div class="select-label select-label-on">{t(locale, 'cookies.cookies_on')}</div>
        <div class="select-label select-label-off">{t(locale, 'cookies.cookies_off')}</div>
      </div>
    </div>
  </div>
</div>
<script is:inline>
  $(function () {
    $('.operationCookiesSwitchButton').change(function () {
      if ($(this).prop('checked')) {
        setCookie('operationCookies', 'true', 36500000);
      } else {
        setCookie('operationCookies', 'false', 36500000);
      }
    });
  });
</script>
<script is:inline>
  localStorage.cookieTipv0Checked = 'true';
</script>
