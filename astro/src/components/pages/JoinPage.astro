---
import { t } from '@/i18n/translate';
import type { PageProps } from './PageProps';

const { locale } = Astro.props as PageProps;
const jobs = ['developer', 'support', 'writer'] as const;
const commonItems = [
  ['nm_heart', 'nm_heart_intro'],
  ['basic_morality', 'basic_morality_intro'],
] as const;
const jobItems = {
  developer: [
    ['knowledge', ''],
    ['experience', 'experience_intro'],
    ['', 'additional'],
  ],
  support: [
    ['part_time', 'part_time_intro'],
    ['attitude', 'attitude_intro'],
    ['bill', 'bill_intro'],
  ],
  writer: [
    ['lan_level', 'lan_level_intro'],
    ['knowledge', ''],
    ['english', ''],
  ],
} as const;
const arrowIcon = `<svg class="svg" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M761.056 532.128c0.512-0.992 1.344-1.824 1.792-2.848 8.8-18.304 5.92-40.704-9.664-55.424L399.936 139.744c-19.264-18.208-49.632-17.344-67.872 1.888-18.208 19.264-17.376 49.632 1.888 67.872l316.96 299.84-315.712 304.288c-19.072 18.4-19.648 48.768-1.248 67.872 9.408 9.792 21.984 14.688 34.56 14.688 12 0 24-4.48 33.312-13.44l350.048-337.376z"></path></svg>`;
---
<div class="title center">
  <h1>{t(locale, 'join.join_requirement_page.title')}</h1>
</div>
<div class="main">
  <div class="mainBlock">
    <p>{t(locale, 'join.join_requirement_page.intro.0')}</p>
    <p>{t(locale, 'join.join_requirement_page.intro.1')}</p>
    <p style="color: #FF0000;">{t(locale, 'join.join_requirement_page.publicity')}</p>
  </div>
  <div class="mainBlock">
    <div class="tabView joinTab" id="joinTab">
      <div class="tabHeader">
        {
          jobs.map((job, index) => (
            <button data-tab={job} data-status={index === 0 ? 'focus' : ''}>
              {t(locale, `join.join_requirement_page.jobs.${job}.title`)}
            </button>
          ))
        }
      </div>
      <div class="tabContents">
        {jobs.map((job, index) => (
          <div class="content" data-tab={job} data-status={index === 0 ? 'focus' : ''}>
            <h2>{t(locale, `join.join_requirement_page.jobs.${job}.title`)}</h2>
            {commonItems.map(([nameKey, detailKey]) => (
              <>
                <p class="requirementName">{t(locale, `join.join_requirement_page.jobs.common.${nameKey}`)}</p>
                <div class="detail">{t(locale, `join.join_requirement_page.jobs.common.${detailKey}`)}</div>
              </>
            ))}
            <p class="requirementName">{t(locale, 'join.join_requirement_page.jobs.common.friendly_wish')}</p>
            {jobItems[job].map(([nameKey, detailKey]) => (
              <>
                {nameKey && <p class="requirementName">{t(locale, `join.join_requirement_page.jobs.${job}.${nameKey}`)}</p>}
                {detailKey && <div class="detail">{t(locale, `join.join_requirement_page.jobs.${job}.${detailKey}`)}</div>}
              </>
            ))}
            <div class="indexMoreLinks">
              <a target="_self" href={`/join/forum?jobType=${job}`}>
                <span>{t(locale, 'join.join_requirement_page.register')}</span>
                <Fragment set:html={arrowIcon} />
              </a>
            </div>
            <div class="detail">{t(locale, 'join.join_requirement_page.language_request')}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
