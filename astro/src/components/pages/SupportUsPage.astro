---
import { getSponsorData } from '@/data/sponsor';
import type { PublicLocale } from '@/i18n/locales';
import { t } from '@/i18n/translate';

interface Props {
  locale: PublicLocale;
}

const { locale } = Astro.props;
const sponsorData = getSponsorData();
const externalLinkIcon =
  '<svg class="svg" style="transform:scale(0.81)" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M924.402464 1023.068211H0.679665V99.345412h461.861399v98.909208H99.596867v725.896389h725.896389V561.206811h98.909208z" p-id="3093"></path><path d="M930.805104 22.977336l69.965436 69.965436-453.492405 453.492404-69.965435-69.901489z" p-id="3094"></path><path d="M1022.464381 304.030081h-98.917201V99.345412H709.230573V0.428211h313.233808z"></path></svg>';
const arrowIcon =
  '<svg class="svg" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M761.056 532.128c0.512-0.992 1.344-1.824 1.792-2.848 8.8-18.304 5.92-40.704-9.664-55.424L399.936 139.744c-19.264-18.208-49.632-17.344-67.872 1.888-18.208 19.264-17.376 49.632 1.888 67.872l316.96 299.84-315.712 304.288c-19.072 18.4-19.648 48.768-1.248 67.872 9.408 9.792 21.984 14.688 34.56 14.688 12 0 24-4.48 33.312-13.44l350.048-337.376c0.672-0.672 0.928-1.6 1.6-2.304 0.512-0.48 1.056-0.832 1.568-1.344C757.76 538.88 759.2 535.392 761.056 532.128z" p-id="2301"></path></svg>';
---
<style>
  .sTab {
    width: 100%;
    max-width: 600px;
    line-height: 2;
    margin: 0 auto 30px auto;
    overflow-x: auto;
  }

  .sTab thead {
    font-weight: bold;
  }

  .sTab td:not(td + td) {
    padding: 5px 0;
    display: inline-flex;
    justify-content: center;
  }

  .sTab i {
    display: inline-block;
    flex-grow: 0;
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    background-image: url(https://static.hdslb.com/images/akari.jpg);
    background-size: 30px 30px;
    border-radius: 20px;
    margin-right: 4px;
  }

  .sTab td + td {
    text-align: end;
    min-width: 5em;
  }
</style>
<div class="title center">
  <h1>{t(locale, 'supportus.title')}</h1>
</div>
<div class="main mainBlock">
  <p set:html={t(locale, 'supportus.para')} />
  <br />
  <div class="tabView sponsorTab" id="sponsorTab">
    <div class="tabHeader">
      <button data-tab="afdian">{t(locale, 'supportus.links.afdian')}</button>
      <button data-tab="patreon">{t(locale, 'supportus.links.patreon')}</button>
      <button data-tab="crypto">{t(locale, 'supportus.crypto')}</button>
    </div>
    <div class="tabContents">
      <div class="content" data-tab="afdian">
        <div class="indexMoreLinks">
          <a target="_blank" href="https://afdian.com/@nmTeam?ref=nmteam.xyz">
            <span>{t(locale, 'supportus.links.afdian')}</span>
            <Fragment set:html={externalLinkIcon} />
          </a>
        </div>
      </div>
      <div class="content" data-tab="patreon">
        <div class="indexMoreLinks">
          <a target="_blank" href="https://www.patreon.com/nmteam?ref=nmteam.xyz">
            <span>{t(locale, 'supportus.links.patreon')}</span>
            <Fragment set:html={externalLinkIcon} />
          </a>
        </div>
      </div>
      <div class="content" data-tab="crypto">
        <p>
          {t(locale, 'supportus.crypto_address')}:
          <span class="address" style="user-select: all; --webkit-user-select: all;">TWvJ6bghs8XM38VHDvUV9unJGZzbnmTeam</span>
        </p>
        <div class="indexMoreLinks">
          <a target="_self" href="javascript:copyCryptoAddress()">
            <span>{t(locale, 'supportus.copy_crypto_address')}</span>
            <Fragment set:html={arrowIcon} />
          </a>
        </div>
        <p>
          <br />
          {t(locale, 'supportus.crypto_only_accept_tron')}
        </p>
        <p>
          <img src="/src/img/tron.jpg" alt="TRON" style="width: 100%; max-width: 300px;" />
        </p>
      </div>
    </div>
  </div>
  <h2>{t(locale, 'supportus.tks_sponsor')} ({t(locale, 'supportus.tks_sponsor_part')})</h2>
  <table class="sTab">
    <thead>
      <tr>
        <td><i style="background: none;"></i>{t(locale, 'supportus.table.name')}</td>
        <td>{t(locale, 'supportus.table.amount')}<span style="visibility: hidden"> CNY</span></td>
      </tr>
    </thead>
    <tbody>
      {
        sponsorData.sponsor.map((sponsor) => (
          <tr>
            <td><i style={`background-image: url(${sponsor.avatar});`} title={t(locale, 'supportus.table.avatar')}></i><span>{sponsor.name}</span></td>
            <td>{sponsor.amount} CNY</td>
          </tr>
        ))
      }
    </tbody>
  </table>
  <h2>{t(locale, 'supportus.tks_other')}</h2>
  <table class="sTab">
    <tbody>
      {
        sponsorData.other.map((other) => (
          <tr>
            <td><i style={`background-image: url(${other.avatar});`} title={t(locale, 'supportus.table.avatar')}></i><b>{other.name}:&nbsp;</b><span>{other.contribution}</span></td>
          </tr>
        ))
      }
    </tbody>
  </table>
  <p class="updateDate" style="font-size: 14px;" set:html={t(locale, 'supportus.sponsors_info_note')} />
</div>
<script is:inline define:vars={{ copySuccess: t(locale, 'supportus.copy_crypto_address_success') }}>
  window.copyCryptoAddress = () => {
    const el = document.createElement('textarea');
    el.value = document.querySelector('.content[data-tab="crypto"] span.address').innerText;
    document.body.appendChild(el);
    el.select();
    document.execCommand('copy');
    document.body.removeChild(el);
    alert(copySuccess);
  };
  document.querySelectorAll('#sponsorTab *').forEach((element) => {
    element.setAttribute('data-status', '');
  });
  document.querySelectorAll('#sponsorTab *[data-tab="afdian"]').forEach((element) => {
    element.setAttribute('data-status', 'focus');
  });
</script>
