---
import { t } from '@/i18n/translate';
import type { PageProps } from './PageProps';

const { locale } = Astro.props as PageProps;
---
<div class="title center">
  <h1>{t(locale, 'status_page.title')}</h1>
</div>
<div class="main">
  <p>
    <center>{t(locale, 'status_page.redirecting')}</center>
  </p>
</div>
<script is:inline>
  window.location.href = "https://status.nmteam.xyz";
</script>
