---
import { t } from '@/i18n/translate';
import type { PageProps } from './PageProps';

const { locale } = Astro.props as PageProps;
const businessEmailAddress = 'business@nmteam.xyz';
---
<style>
  .email-btn {
    display: inline-block;
    padding: 8px 20px;
    margin: 5px 0;
    font-size: 17px;
    font-weight: bold;
    text-align: center;
    border: none;
    border-radius: 4px;
    color: #000;
    background-color: #ead050;
    text-decoration: none;
    user-select: all;
    -webkit-user-select: all;
    -moz-user-select: all;
  }
</style>
<div class="title center">
  <h1>{t(locale, 'business_cooperation.title')}</h1>
</div>
<div class="main">
  <div class="mainBlock">
    <p>{t(locale, 'business_cooperation.content_0')}</p>
    <p>
      <button class="email-btn" onclick={`window.location.href='mailto:${businessEmailAddress}'`}>{businessEmailAddress}</button>
      &nbsp;&nbsp;<a href="javascript:" onclick="copyEmail()">{t(locale, 'business_cooperation.copy_email')}</a>
    </p>
    <p>{t(locale, 'business_cooperation.content_1')}</p>
  </div>
</div>
<script is:inline define:vars={{ businessEmailAddress }}>
  window.copyEmail = function () {
    var tempInput = document.createElement('input');
    tempInput.value = businessEmailAddress;
    document.body.appendChild(tempInput);
    tempInput.select();
    document.execCommand('copy');
    document.body.removeChild(tempInput);
  };
</script>
