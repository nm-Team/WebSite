---
import AboutPage from './AboutPage.astro';
import BusinessCooperationPage from './BusinessCooperationPage.astro';
import CookiesPage from './CookiesPage.astro';
import NetworkServiceProtocolPage from './NetworkServiceProtocolPage.astro';
import PlaceholderPage from './PlaceholderPage.astro';
import PrivacyPolicyPage from './PrivacyPolicyPage.astro';
import ProductDetailPage from '@/components/products/ProductDetailPage.astro';
import ProductOverviewPage from '@/components/products/ProductOverviewPage.astro';
import type { PageProps } from './PageProps';
import StatusPage from './StatusPage.astro';
import SupportPage from './SupportPage.astro';
import SupportUsPage from './SupportUsPage.astro';

const props = Astro.props as PageProps;

const pageComponents = {
  aboutus: AboutPage,
  cookies: CookiesPage,
  'business-cooperation': BusinessCooperationPage,
  'legal-privacy-policy': PrivacyPolicyPage,
  'legal-network-service-protocol': NetworkServiceProtocolPage,
  products: ProductOverviewPage,
  support: SupportPage,
  supportus: SupportUsPage,
  status: StatusPage,
} as const;

const kindComponents = {
  'generic-product-page': ProductDetailPage,
} as const;

const PageComponent =
  kindComponents[props.route.kind as keyof typeof kindComponents] ??
  pageComponents[props.route.id as keyof typeof pageComponents] ??
  PlaceholderPage;
---
<PageComponent {...props} />
