---
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import LanguageSwitcher from '@/components/layout/LanguageSwitcher.astro';
import { isPublicLocale, publicLocales, type PublicLocale } from '@/i18n/locales';
import { routeManifest } from '@/i18n/routes';
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return publicLocales.flatMap((lang) =>
    routeManifest.map((route) => ({
      params: {
        lang,
        slug: route.slug.length === 0 ? undefined : route.slug.join('/'),
      },
    })),
  );
}

const lang = Astro.params.lang ?? '';
const slugParam = Astro.params.slug;
const slug = slugParam ? slugParam.split('/') : [];
if (!isPublicLocale(lang)) {
  throw new Error(`Unsupported locale: ${lang}`);
}

const title = slug.length === 0 ? `${lang} Home` : `${lang} / ${slug.join('/')}`;
---
<BaseLayout title={title} lang={lang}>
  <Header />
  <LanguageSwitcher currentLocale={lang as PublicLocale} slug={slug} />
  <main>
    <h1>{title}</h1>
    <p>Prefixed routes never run automatic language redirect.</p>
  </main>
  <Footer />
</BaseLayout>
