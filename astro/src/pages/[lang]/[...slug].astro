---
import { isPublicLocale, publicLocales, type PublicLocale } from '@/i18n/locales';
import { routeManifest, type RouteEntry } from '@/i18n/routes';
import PageContent from '@/components/pages/PageContent.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return publicLocales.flatMap((lang) =>
    routeManifest.filter((route) => route.supportedLocales.includes(lang)).map((route) => ({
      params: {
        lang,
        slug: route.slug.length === 0 ? undefined : route.slug.join('/'),
      },
      props: { route },
    })),
  );
}

interface Props {
  route: RouteEntry;
}

const { route } = Astro.props as Props;
const lang = Astro.params.lang ?? '';
if (!isPublicLocale(lang)) {
  throw new Error(`Unsupported locale: ${lang}`);
}

const currentLocale = lang as PublicLocale;
---
<BaseLayout
  titleKey={route.pageTitle}
  keywordsKey={route.pageKeywords}
  descriptionKey={route.pageDescription}
  headCss={route.pageHeadCss}
  headJs={route.pageHeadJs}
  bodyJs={route.pageBodyJs}
  image={route.pageImage}
  pageUpdate={route.pageUpdate}
  constTheme={route.id === 'products-overview-nmbot-telegram' ? 'dark' : undefined}
  disallowHideHeader={route.id === 'products-overview-nmbot-telegram'}
  lang={currentLocale}
>
  <PageContent route={route} locale={currentLocale} />
</BaseLayout>
