---
import { defaultLocale } from '@/i18n/locales';
import { routeManifest, type RouteEntry } from '@/i18n/routes';
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return routeManifest.map((route) => ({
    params: {
      slug: route.slug.length === 0 ? undefined : route.slug.join('/'),
    },
    props: { route },
  }));
}

interface Props {
  route: RouteEntry;
}

const { route } = Astro.props as Props;
const title = route.slug.length === 0 ? '' : route.slug.join('/');
---
<BaseLayout
  titleKey={route.pageTitle}
  keywordsKey={route.pageKeywords}
  descriptionKey={route.pageDescription}
  headCss={route.pageHeadCss}
  headJs={route.pageHeadJs}
  bodyJs={route.pageBodyJs}
  image={route.pageImage}
  pageUpdate={route.pageUpdate}
  lang={defaultLocale}
  enableLanguageRedirect
>
  <main>
    <h1>{title || 'Home'}</h1>
    <p>Unprefixed route renders English fallback and may redirect for users.</p>
  </main>
</BaseLayout>
